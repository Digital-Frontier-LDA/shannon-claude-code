#!/usr/bin/env bash
# shannon — operational helper for the Claude Code native Shannon pentest tool.
#   shannon doctor         check the environment + what's installed
#   shannon install-tools  install the optional scanners (nmap/sqlmap/whatweb/…)
#   shannon update         git-pull the source repo + re-run install.sh
#   shannon uninstall      remove the globally-installed skill/agents/hook/MCP
#
# Derivative of Shannon (https://github.com/KeygraphHQ/shannon), AGPL-3.0.
set -euo pipefail

SHANNON_HOME="${SHANNON_HOME:-$HOME/.shannon}"
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
SETTINGS="$CLAUDE_DIR/settings.json"
CLAUDE_JSON="$HOME/.claude.json"
ok()   { printf '  ✓ %s\n' "$*"; }
bad()  { printf '  ✗ %s\n' "$*"; }
warn() { printf '  ! %s\n' "$*"; }

cmd_doctor() {
  echo "Shannon doctor"
  echo "Required:"
  for b in node npm jq claude; do command -v "$b" >/dev/null 2>&1 && ok "$b ($(command -v "$b"))" || bad "$b MISSING"; done
  echo "Optional scanners (pipeline skips if absent):"
  local missing=0
  for b in nmap subfinder whatweb sqlmap oathtool; do command -v "$b" >/dev/null 2>&1 && ok "$b" || { warn "$b not installed"; missing=1; }; done
  [ "$missing" -eq 1 ] && echo "  → install the missing ones with: shannon install-tools"
  echo "Installed:"
  [ -f "$CLAUDE_DIR/skills/pentest/SKILL.md" ] && ok "/pentest skill" || bad "/pentest skill NOT installed — run ./install.sh"
  local n; n="$(ls "$CLAUDE_DIR"/agents/{shannon-pre-recon,shannon-recon,shannon-report}.md 2>/dev/null | wc -l | tr -d ' ')"
  [ "${n:-0}" -ge 1 ] && ok "agents present" || bad "agents NOT installed"
  [ -f "$SHANNON_HOME/native/mcp-stdio-wrapper.mjs" ] && ok "shannon-tools MCP payload" || bad "MCP payload missing in $SHANNON_HOME"
  [ -d "$SHANNON_HOME/native/node_modules" ] && ok "MCP deps installed" || bad "MCP deps missing — run ./install.sh"
  if [ -f "$CLAUDE_JSON" ]; then
    jq -e '.mcpServers["shannon-tools"]' "$CLAUDE_JSON" >/dev/null 2>&1 && ok "shannon-tools registered in ~/.claude.json" || bad "shannon-tools NOT registered"
    jq -e '.mcpServers.playwright' "$CLAUDE_JSON" >/dev/null 2>&1 && ok "playwright registered" || warn "playwright NOT registered"
  else bad "~/.claude.json absent"; fi
  if [ -f "$SETTINGS" ]; then
    jq -e '[.permissions.allow // [] | .[] | select(test("nmap|sqlmap"))] | length > 0' "$SETTINGS" >/dev/null 2>&1 \
      && ok "security-tool permission allowlist present" || warn "permission allowlist not merged — expect prompts"
  fi
}

cmd_install_tools() {
  echo "Installing optional scanners for the Shannon pipeline…"
  if command -v apt-get >/dev/null 2>&1; then
    echo "→ apt (Debian/Ubuntu) — installs nmap, sqlmap, whatweb, oathtool"
    sudo apt-get update -qq
    # whatweb is packaged on apt; oathtool ships in the oathtool package
    sudo apt-get install -y nmap sqlmap whatweb oathtool || warn "some apt packages failed — see output above"
    command -v subfinder >/dev/null 2>&1 || warn "subfinder has no apt package — 'go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest' (needs Go), optional"
  elif command -v brew >/dev/null 2>&1; then
    echo "→ brew (macOS) — installs nmap, sqlmap, oath-toolkit, subfinder"
    brew install nmap sqlmap oath-toolkit subfinder || warn "some brew formulae failed — see output above"
    # whatweb: no Homebrew formula and no rubygem → clone upstream + a PATH wrapper.
    if command -v whatweb >/dev/null 2>&1; then
      ok "whatweb already on PATH"
    else
      local wdir="$SHANNON_HOME/tools/WhatWeb"
      mkdir -p "$SHANNON_HOME/tools"
      if [ -d "$wdir/.git" ]; then
        echo "  whatweb: updating clone at $wdir"; git -C "$wdir" pull --ff-only -q || warn "whatweb pull failed (keeping existing clone)"
      else
        echo "  whatweb: cloning urbanadventurer/WhatWeb → $wdir"; git clone --depth 1 https://github.com/urbanadventurer/WhatWeb "$wdir"
      fi
      # Pick a bindir that's on PATH and writable; fall back to ~/.shannon/bin.
      local bindir; bindir="$(dirname "$(command -v brew)")"   # e.g. /opt/homebrew/bin or /usr/local/bin
      if [ ! -w "$bindir" ]; then mkdir -p "$SHANNON_HOME/bin"; bindir="$SHANNON_HOME/bin"; fi
      # A wrapper, NOT a symlink: WhatWeb resolves its lib/ relative to the real script path,
      # so it must be exec'd in place.
      printf '#!/usr/bin/env bash\nexec "%s/whatweb" "$@"\n' "$wdir" > "$bindir/whatweb"
      chmod +x "$bindir/whatweb"
      ok "whatweb → $bindir/whatweb"
      if [ "$bindir" = "$SHANNON_HOME/bin" ]; then
        warn "add to PATH:  export PATH=\"$SHANNON_HOME/bin:\$PATH\""
      fi
      echo "  (basic fingerprinting runs on system Ruby; for the full plugin set: cd $wdir && bundle install)"
    fi
  else
    bad "no apt-get or brew found — install manually: nmap, sqlmap, whatweb, oathtool, subfinder"
    return 1
  fi
  echo "Done. Verify with: shannon doctor"
}

cmd_update() {
  local src; src="$(cat "$SHANNON_HOME/.source-path" 2>/dev/null || true)"
  [ -n "$src" ] && [ -d "$src/.git" ] || { echo "no git source recorded; re-clone the repo and run ./install.sh"; exit 1; }
  echo "Updating from $src"
  git -C "$src" pull --ff-only
  exec "$src/install.sh"
}

cmd_uninstall() {
  echo "Removing globally-installed Shannon assets (your settings.json/.claude.json backups are kept):"
  rm -rf "$CLAUDE_DIR/skills/pentest" && echo "  removed skills/pentest"
  rm -f "$CLAUDE_DIR/hooks/shannon-audit-logger.sh" && echo "  removed audit hook"
  for a in shannon-pre-recon shannon-recon shannon-report shannon-vuln-injection shannon-vuln-xss shannon-vuln-auth shannon-vuln-authz shannon-vuln-ssrf shannon-exploit-injection shannon-exploit-xss shannon-exploit-auth shannon-exploit-authz shannon-exploit-ssrf; do
    rm -f "$CLAUDE_DIR/agents/$a.md"
  done; echo "  removed agents"
  if [ -f "$CLAUDE_JSON" ]; then
    jq 'del(.mcpServers["shannon-tools"]) | del(.mcpServers.playwright)' "$CLAUDE_JSON" > "$CLAUDE_JSON.tmp" && mv "$CLAUDE_JSON.tmp" "$CLAUDE_JSON"
    echo "  unregistered MCP servers"
  fi
  echo "Note: the permission-allowlist entries merged into $SETTINGS were left in place."
  echo "      To revert them, restore a $SETTINGS.shannon-bak.* backup. Payload at $SHANNON_HOME kept."
}

case "${1:-}" in
  doctor)        cmd_doctor ;;
  install-tools) cmd_install_tools ;;
  update)        cmd_update ;;
  uninstall)     cmd_uninstall ;;
  *) echo "usage: shannon {doctor|install-tools|update|uninstall}"; exit 1 ;;
esac
